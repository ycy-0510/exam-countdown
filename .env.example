# Instagram API 設定
# 1. 前往 Facebook Developers (https://developers.facebook.com/) 建立應用程式
# 2. 取得 Instagram 專業帳號的 ID
IG_ACCOUNT_ID="your_instagram_account_id"

# 3. 取得長效 User Access Token (需有 instagram_basic, instagram_content_publish 權限)
IG_ACCESS_TOKEN="your_long_lived_access_token"

# Cloudinary 圖床設定
# 1. 前往 https://cloudinary.com/ 註冊並取得 API Environment variable
# 範例格式: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL="cloudinary://my_key:my_secret@my_cloud_name"

# 考試倒數設定
# 支援使用 EXAM_DATE (格式 YYYY-MM-DD) 或 EXAM_DATETIME (格式 YYYY-MM-DD HH:MM:SS)
# EXAM_DATE="2026-07-01"
EXAM_DATETIME="2026-07-01 00:00:00"
EXAM_NAME="115會考"

# Discord Webhook 設定 (選填)
# 前往 Discord 伺服器 > 頻道設定 > 整合 > Webhooks 建立並取得網址
DISCORD_WEBHOOK_URL=""

SCHEDULE_TIME="07:00"
