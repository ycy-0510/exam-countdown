# Instagram API 設定
# 1. 前往 Facebook Developers (https://developers.facebook.com/) 建立應用程式
# 2. 取得 Instagram 專業帳號的 ID
IG_ACCOUNT_ID="your_instagram_account_id"

# 3. 取得長效 User Access Token (需有 instagram_basic, instagram_content_publish 權限)
IG_ACCESS_TOKEN="your_long_lived_access_token"

# Cloudinary Setup
# 1. Visit https://cloudinary.com/ and get API Environment variable
# Ex: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL="cloudinary://my_key:my_secret@my_cloud_name"

# Exam Countdown Settings
# Target exam date in YYYY-MM-DD format
# EXAM_DATE="2026-05-16"
EXAM_DATETIME="2026-05-16 08:00:00"
EXAM_NAME="115會考"

# Discord Webhook Settings (optional)
# Visit your Discord server > Channel Settings > Integrations > Webhooks to create and get the URL
DISCORD_WEBHOOK_URL=""

SCHEDULE_TIME="07:00"
