# Instagram API Setup
# 1. Visit Facebook Developers (https://developers.facebook.com/) to create an app
# 2. Get the ID of your Instagram Professional Account
IG_ACCOUNT_ID="your_instagram_account_id"

# 3. Get a long-lived User Access Token (requires instagram_basic, instagram_content_publish permissions)
IG_ACCESS_TOKEN="your_long_lived_access_token"

# Facebook Page Setup (optional, for cross-posting)
# 1. Get your Facebook Page ID
# 2. Get a Page Access Token with publish permissions
FACEBOOK_PAGE_ID="your_facebook_page_id"
FACEBOOK_ACCESS_TOKEN="your_facebook_page_access_token"

# Cloudinary Setup
# 1. Visit https://cloudinary.com/ and get API Environment variable
# Ex: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL="cloudinary://my_key:my_secret@my_cloud_name"

# Exam Countdown Settings
# Target exam date in YYYY-MM-DD format
# EXAM_DATE="2026-05-16"
EXAM_DATETIME="2026-05-16 08:00:00"
EXAM_NAME="115會考"

# Discord Webhook Settings (optional)
# Visit your Discord server > Channel Settings > Integrations > Webhooks to create and get the URL
DISCORD_WEBHOOK_URL=""

SCHEDULE_TIME="07:00"
